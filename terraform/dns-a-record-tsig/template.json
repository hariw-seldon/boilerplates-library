{
  "slug": "dns-a-record-tsig",
  "kind": "terraform",
  "metadata": {
    "name": "DNS Record A (TSIG)",
    "description": "Creates a DNS A record using TSIG-authenticated dynamic DNS updates. Maps a hostname to an IP address on a TSIG-enabled DNS server.",
    "icon": {
      "provider": "selfhst",
      "id": "bind-9",
      "color": "default"
    },
    "draft": false,
    "version": {
      "name": "3.5.0",
      "source_dep_name": "hashicorp/dns",
      "source_dep_version": "3.5.0"
    }
  },
  "variables": [
    {
      "name": "dns",
      "title": "DNS Server Configuration",
      "items": [
        {
          "name": "dns_server",
          "title": "DNS server address",
          "description": "DNS server address to use.",
          "type": "str",
          "required": true
        },
        {
          "name": "dns_server_tsig_key_secret",
          "title": "TSIG key secret",
          "description": "TSIG key secret value.",
          "type": "secret",
          "required": true
        }
      ]
    },
    {
      "name": "record",
      "title": "DNS Record Configuration",
      "items": [
        {
          "name": "dns_hostname",
          "title": "Hostname",
          "description": "Hostname used for the DNS record.",
          "type": "str",
          "config": {
            "placeholder": "hostname"
          },
          "required": true
        },
        {
          "name": "dns_zone",
          "title": "Zone",
          "description": "Zone used for the DNS record.",
          "type": "str",
          "config": {
            "placeholder": "home.arpa."
          },
          "required": true
        },
        {
          "name": "ip_address",
          "title": "IP Address",
          "description": "IP address to map to the hostname.",
          "type": "str",
          "config": {
            "placeholder": "192.168.0.1/24"
          },
          "required": true
        },
        {
          "name": "dns_ttl",
          "title": "TTL",
          "description": "Time to live (TTL) for the DNS record in seconds (default: 3600)",
          "type": "int",
          "default": 3600,
          "config": {
            "unit": "seconds",
            "slider": true,
            "min": 60,
            "max": 86400,
            "step": 60
          }
        }
      ]
    }
  ]
}
