          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "ztna_app",
          "description": "Terraform resource name (alphanumeric and underscores only)",
          "config": {
            "placeholder": "ztna_app"
          }
        },
        {
          "name": "zone_id_value",
