{
  "slug": "cloudflare-ztna-application",
  "kind": "terraform",
  "metadata": {
    "name": "Cloudflare Zero Trust Access Application",
    "description": "Creates a Cloudflare Zero Trust Access application with service token and IP-based access policies.",
    "tags": [],
    "template_version": "5.12.0",
    "icon": {
      "provider": "selfhst",
      "id": "cloudflare-zero-trust"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "Application",
      "name": "application",
      "items": [
        {
          "name": "app_name",
          "type": "str",
          "title": "Application name",
          "required": false,
          "default": "application",
          "description": "Name to use for the application.",
          "config": {
            "placeholder": "application"
          }
        },
        {
          "name": "domain",
          "type": "str",
          "title": "Application domain",
          "required": false,
          "description": "Domain used for Application.",
          "config": {
            "placeholder": "app.home.arpa"
          }
        },
        {
          "name": "session_duration",
          "type": "str",
          "title": "Session Duration",
          "required": false,
          "default": "15m",
          "description": "Session duration (e.g., 15m, 1h, 24h)",
          "config": {
            "placeholder": "15m"
          }
        }
      ]
    },
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "account_id_value",
          "type": "str",
          "title": "Cloudflare Account ID",
          "required": false,
          "description": "Cloudflare account identifier."
        },
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "ztna_app",
          "description": "Terraform resource name (alphanumeric and underscores only)",
          "config": {
            "placeholder": "ztna_app"
          }
        },
        {
          "name": "zone_id_value",
          "type": "str",
          "title": "Cloudflare Zone ID",
          "required": false,
          "description": "Cloudflare zone identifier."
        }
      ]
    },
    {
      "title": "IP-Based Policy",
      "name": "ip-policy",
      "items": [
        {
          "name": "ip_policy_enabled",
          "type": "bool",
          "title": "IP Policy",
          "required": false,
          "default": false,
          "description": "Enable IP-based policy"
        },
        {
          "name": "ip_policy_name",
          "type": "str",
          "title": "IP Policy Name",
          "required": false,
          "default": "ip_policy",
          "description": "Policy name for IP-based access",
          "config": {
            "placeholder": "ip_policy"
          }
        },
        {
          "name": "ip_ranges",
          "type": "str",
          "title": "IP Ranges",
          "required": false,
          "default": "IP_RANGE",
          "description": "Comma-separated list of IP ranges (CIDR notation)",
          "needs": [
            "ip_policy_enabled=true"
          ],
          "config": {
            "placeholder": "IP_RANGE"
          }
        }
      ]
    },
    {
      "title": "Service Token Policy",
      "name": "service-token-policy",
      "items": [
        {
          "name": "service_token_enabled",
          "type": "bool",
          "title": "Service Token",
          "required": false,
          "default": false,
          "description": "Enable service token policy"
        },
        {
          "name": "service_token_id",
          "type": "str",
          "title": "Service Token ID",
          "required": false,
          "description": "Cloudflare service token ID",
          "needs": [
            "service_token_enabled=true"
          ]
        },
        {
          "name": "service_token_policy_name",
          "type": "str",
          "title": "Service Token Name",
          "required": false,
          "default": "service_token_policy",
          "description": "Name to use for the service token.",
          "needs": [
            "service_token_enabled=true"
          ],
          "config": {
            "placeholder": "service_token_policy"
          }
        }
      ]
    },
    {
      "title": "Dependencies",
      "name": "depends-on",
      "items": [
        {
          "name": "depends_on_enabled",
          "type": "bool",
          "title": "Dependencies",
          "required": false,
          "default": false,
          "description": "Enable resource dependencies"
        },
        {
          "name": "dependencies",
          "type": "str",
          "title": "Dependencies",
          "required": false,
          "default": "",
          "description": "Comma-separated list of resource dependencies",
          "needs": [
            "depends_on_enabled=true"
          ],
          "config": {
            "textarea": true
          }
        }
      ]
    },
    {
      "title": "Lifecycle",
      "name": "lifecycle",
      "items": [
        {
          "name": "lifecycle_enabled",
          "type": "bool",
          "title": "Lifecycle",
          "required": false,
          "default": false,
          "description": "Enable lifecycle rules"
        },
        {
          "name": "prevent_destroy",
          "type": "bool",
          "title": "Prevent resource destruction",
          "required": false,
          "default": false,
          "description": "Prevent Terraform from destroying the resource.",
          "needs": [
            "lifecycle_enabled=true"
          ]
        },
        {
          "name": "create_before_destroy",
          "type": "bool",
          "title": "Precreate",
          "required": false,
          "default": false,
          "description": "Create replacement before destroying",
          "needs": [
            "lifecycle_enabled=true"
          ]
        },
        {
          "name": "ignore_changes",
          "type": "str",
          "title": "Ignore Changes",
          "required": false,
          "default": "",
          "description": "Comma-separated list of attributes to ignore changes for",
          "needs": [
            "lifecycle_enabled=true"
          ],
          "config": {
            "textarea": true
          }
        }
      ]
    }
  ]
}
