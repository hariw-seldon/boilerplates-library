{
  "slug": "netbird-network",
  "kind": "terraform",
  "metadata": {
    "name": "NetBird Network",
    "description": "Creates a NetBird network for organizing resources and routers.",
    "tags": [
      "netbird",
      "terraform"
    ],
    "icon": {
      "provider": "selfhst",
      "id": "netbird"
    },
    "draft": false,
    "version": {
      "name": "0.0.10",
      "source_dep_name": "manual/netbird-network"
    }
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": true,
          "description": "Name of the NetBird network.",
          "config": {
            "placeholder": "Homelab"
          }
        },
        {
          "name": "network_description",
          "type": "str",
          "title": "Description",
          "required": false,
          "description": "Optional description for the NetBird network.",
          "config": {
            "placeholder": "Internal services network",
            "textarea": true
          }
        }
      ]
    },
    {
      "title": "Provider Configuration",
      "name": "provider",
      "items": [
        {
          "name": "netbird_management_url",
          "type": "str",
          "title": "Management URL",
          "required": false,
          "default": "https://api.netbird.io",
          "description": "NetBird Management API URL. Trailing slashes are trimmed. TLS certificates must be trusted by the OpenTofu runner because the provider does not expose a skip-verification option.",
          "config": {
            "placeholder": "https://api.netbird.io"
          }
        },
        {
          "name": "netbird_pat",
          "type": "secret",
          "title": "Admin PAT",
          "required": true,
          "description": "NetBird admin personal access token (PAT)."
        },
        {
          "name": "netbird_tenant_account",
          "type": "str",
          "title": "Tenant Account",
          "required": false,
          "description": "Optional tenant account ID for impersonation.",
          "config": {
            "placeholder": "account-id"
          }
        }
      ]
    }
  ]
}
