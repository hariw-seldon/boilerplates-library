{
  "slug": "proxmox-provider",
  "kind": "terraform",
  "metadata": {
    "name": "Proxmox Provider",
    "description": "Configures the Telmate Proxmox Terraform provider for Proxmox API access.",
    "tags": [
      "proxmox",
      "terraform",
      "provider"
    ],
    "icon": {
      "provider": "selfhst",
      "id": "proxmox"
    },
    "draft": false,
    "version": {
      "name": "3.0.2-rc07",
      "source_dep_name": "telmate/proxmox",
      "source_dep_version": "3.0.2-rc07"
    }
  },
  "variables": [
    {
      "title": "Provider Configuration",
      "name": "provider",
      "items": [
        {
          "name": "proxmox_api_url",
          "type": "str",
          "title": "Proxmox API URL",
          "required": true,
          "description": "URL for the Proxmox API.",
          "config": {
            "placeholder": "https://proxmox.home.arpa:8006/api2/json"
          }
        },
        {
          "name": "proxmox_api_token_id",
          "type": "str",
          "title": "API Token ID",
          "required": true,
          "description": "Proxmox API token ID",
          "config": {
            "placeholder": "terraform@pve!token"
          }
        },
        {
          "name": "proxmox_api_token_secret",
          "type": "secret",
          "title": "API Token Secret",
          "required": true,
          "description": "Proxmox API token secret"
        },
        {
          "name": "proxmox_tls_insecure",
          "type": "bool",
          "title": "TLS Verify",
          "required": false,
          "default": false,
          "description": "Skip TLS verification for the Proxmox API"
        }
      ]
    }
  ]
}
