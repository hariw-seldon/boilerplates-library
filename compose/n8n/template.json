{
  "slug": "n8n",
  "kind": "compose",
  "metadata": {
    "name": "N8N",
    "description": "Source-available workflow automation tool that connects apps and services to automate tasks through a visual drag-and-drop node editor.",
    "guide": "## Overview\nSource-available workflow automation tool that connects apps and services to automate tasks through a visual drag-and-drop node editor.\n\n## Prerequisites\n- Set a stable `encryption_key` before production use so stored credentials remain decryptable across restarts.\n- Use an external PostgreSQL or MySQL database for production workloads, and add Redis before enabling queue mode.\n- Prepare the public editor URL, webhook URL, and proxy headers before putting n8n behind Traefik or another reverse proxy.\n\n## Deploy\n- Render the generated files, confirm whether the deployment should use direct port publishing or Traefik, and review the database and queue settings.\n- Start the stack with `docker compose up -d` and watch the logs until the editor is reachable.\n\n## Post-Install\n- Complete the initial owner setup flow, then store the encryption key and database credentials with your backup records.\n- Test one manual execution and one webhook-triggered workflow before onboarding real automations.\n- If metrics are enabled, add the `/metrics` endpoint to your monitoring stack.\n\n## References\n- [n8n](https://n8n.io/)\n- [Documentation](https://docs.n8n.io/)\n- [GitHub](https://github.com/n8n-io/n8n)",
    "tags": [
      "traefik",
      "database"
    ],
    "template_version": "2.8.3",
    "icon": {
      "provider": "selfhst",
      "id": "n8n"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "variables": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "n8n",
          "config": {
            "placeholder": "n8n"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "n8n-server",
          "config": {
            "placeholder": "n8n-server"
          },
          "description": "Name to use for the container."
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false,
          "default": "n8n-server",
          "config": {
            "placeholder": "n8n-server"
          },
          "description": "Hostname used inside the container."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "container_loglevel",
          "type": "enum",
          "title": "Log Level",
          "required": false,
          "config": {
            "options": [
              "debug",
              "info",
              "warn",
              "error"
            ]
          },
          "description": "Container Loglevel"
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        }
      ],
      "name": "general"
    },
    {
      "title": "Traefik",
      "variables": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik Enabled",
          "required": false,
          "default": false,
          "needs": [
            "network_mode=bridge"
          ],
          "description": "Enable or disable traefik enabled."
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": false,
          "config": {
            "placeholder": "n8n"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_webhook_host",
          "type": "str",
          "title": "Webhook Host",
          "required": false,
          "default": "",
          "description": "Separate hostname for webhooks (optional)",
          "needs": [
            "traefik_enabled=true"
          ]
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Traefik Entrypoint",
          "required": false,
          "default": "",
          "description": "Traefik entrypoint name."
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Traefik network name",
          "required": false,
          "default": "traefik",
          "description": "Name to use for the traefik network.",
          "needs": [
            "traefik_enabled=true"
          ],
          "config": {
            "placeholder": "traefik"
          }
        },
        {
          "name": "traefik_network_external",
          "type": "bool",
          "title": "External Traefik Network",
          "required": false,
          "default": true,
          "description": "Use external Traefik network",
          "needs": [
            "traefik_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "Traefik Tls Entrypoint",
          "required": false,
          "default": "",
          "description": "Traefik TLS entrypoint name.",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ],
      "name": "traefik",
      "toggle": "traefik_enabled"
    },
    {
      "title": "Queue Mode",
      "toggle": "queue_enabled",
      "variables": [
        {
          "name": "queue_enabled",
          "type": "bool",
          "title": "Queue Mode",
          "required": false,
          "default": false,
          "description": "Enable queue mode (requires Redis)"
        },
        {
          "name": "queue_redis_external",
          "type": "bool",
          "title": "External Redis",
          "required": false,
          "default": false,
          "description": "Use external Redis instance",
          "needs": [
            "queue_enabled=true"
          ]
        },
        {
          "name": "queue_redis_host",
          "type": "str",
          "title": "Redis host",
          "required": false,
          "default": "redis",
          "description": "Hostname used for Redis.",
          "needs": [
            "queue_enabled=true"
          ],
          "config": {
            "placeholder": "redis"
          }
        },
        {
          "name": "queue_redis_port",
          "type": "int",
          "title": "Redis port",
          "required": false,
          "default": 6379,
          "description": "Port used for Redis.",
          "needs": [
            "queue_enabled=true"
          ],
          "config": {
            "placeholder": "6379"
          }
        },
        {
          "name": "queue_embedded_worker",
          "type": "bool",
          "title": "Embedded Worker",
          "required": false,
          "default": false,
          "description": "Include embedded worker in this deployment",
          "needs": [
            "queue_enabled=true"
          ]
        }
      ],
      "name": "queue"
    },
    {
      "title": "Database",
      "toggle": "database_enabled",
      "variables": [
        {
          "name": "database_enabled",
          "type": "bool",
          "title": "External Database",
          "required": false,
          "default": false,
          "description": "Use external database"
        },
        {
          "name": "database_type",
          "type": "enum",
          "title": "Database type",
          "required": false,
          "default": "postgres",
          "description": "Database engine to use.",
          "needs": [
            "database_enabled=true"
          ],
          "config": {
            "options": [
              "postgres",
              "mysql"
            ]
          }
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "default": "postgres",
          "description": "Hostname of the database server.",
          "needs": [
            "database_enabled=true"
          ],
          "config": {
            "placeholder": "postgres"
          }
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": false,
          "default": 5432,
          "description": "Port used by the database server.",
          "needs": [
            "database_enabled=true"
          ],
          "config": {
            "placeholder": "5432"
          }
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "default": "n8n",
          "description": "Name of the database.",
          "needs": [
            "database_enabled=true"
          ],
          "config": {
            "placeholder": "n8n"
          }
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database username",
          "required": false,
          "default": "n8n",
          "description": "Username for the database.",
          "needs": [
            "database_enabled=true"
          ],
          "config": {
            "placeholder": "n8n"
          }
        },
        {
          "name": "database_password",
          "type": "secret",
          "title": "Database password",
          "required": false,
          "description": "Password for the database.",
          "needs": [
            "database_enabled=true"
          ]
        }
      ],
      "name": "database"
    },
    {
      "title": "Security",
      "variables": [
        {
          "name": "encryption_key",
          "type": "secret",
          "title": "Encryption Key",
          "required": false,
          "description": "N8N encryption key for credentials",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "proxy_hops",
          "type": "int",
          "title": "Proxy Hops",
          "required": false,
          "default": 1,
          "description": "Number of proxy hops (X-Forwarded-For)",
          "config": {
            "placeholder": "1",
            "unit": "hops"
          }
        }
      ],
      "name": "security"
    },
    {
      "title": "Webhooks",
      "variables": [
        {
          "name": "webhook_url",
          "type": "str",
          "title": "Webhook base URL",
          "required": false,
          "default": "",
          "description": "Base URL used for webhooks."
        }
      ],
      "name": "webhooks"
    },
    {
      "title": "Metrics",
      "toggle": "metrics_enabled",
      "variables": [
        {
          "name": "metrics_enabled",
          "type": "bool",
          "title": "Prometheus",
          "required": false,
          "default": false,
          "description": "Enable Prometheus metrics"
        },
        {
          "name": "metrics_detailed",
          "type": "bool",
          "title": "Detailed Metrics",
          "required": false,
          "default": false,
          "description": "Include detailed metrics (workflows, nodes, API endpoints)",
          "needs": [
            "metrics_enabled=true"
          ]
        }
      ],
      "name": "metrics"
    },
    {
      "title": "Execution Settings",
      "variables": [
        {
          "name": "execution_save_on_error",
          "type": "enum",
          "title": "Save on Error",
          "required": false,
          "default": "all",
          "description": "Save execution data on error",
          "config": {
            "options": [
              "all",
              "none"
            ]
          }
        },
        {
          "name": "execution_save_on_success",
          "type": "enum",
          "title": "Save on Success",
          "required": false,
          "default": "none",
          "description": "Save execution data on success",
          "config": {
            "options": [
              "all",
              "none"
            ]
          }
        }
      ],
      "name": "execution"
    },
    {
      "title": "Network",
      "variables": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false,
          "description": "Mode used for Network."
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": "n8n_network",
          "config": {
            "placeholder": "n8n_network"
          },
          "description": "Name to use for the network."
        },
        {
          "name": "network_external",
          "type": "bool",
          "title": "External Network",
          "required": false,
          "default": false,
          "description": "Whether the network is external"
        }
      ],
      "name": "network"
    },
    {
      "title": "Ports",
      "variables": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "External HTTP port",
          "required": false,
          "default": 5678,
          "description": "Port used for External HTTP.",
          "needs": [
            "traefik_enabled=false",
            "network_mode=bridge"
          ],
          "config": {
            "placeholder": "5678"
          }
        }
      ],
      "name": "ports"
    }
  ]
}
