{
  "slug": "n8n",
  "kind": "compose",
  "metadata": {
    "name": "N8N",
    "description": "Source-available workflow automation tool that connects apps and services to automate tasks through a visual drag-and-drop node editor.",
    "tags": [
      "traefik",
      "database"
    ],
    "icon": {
      "provider": "selfhst",
      "id": "n8n"
    },
    "draft": false,
    "version": {
      "name": "2.8.3",
      "source_dep_name": "docker.n8n.io/n8nio/n8n",
      "source_dep_version": "2.8.3"
    }
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "n8n",
          "config": {
            "placeholder": "n8n"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "n8n",
          "config": {
            "placeholder": "n8n"
          },
          "description": "Name to use for the container."
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false,
          "default": "n8n",
          "config": {
            "placeholder": "n8n"
          },
          "description": "Hostname used inside the container."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "container_loglevel",
          "type": "enum",
          "title": "Log Level",
          "required": false,
          "default": "info",
          "config": {
            "options": [
              "debug",
              "info",
              "warn",
              "error"
            ]
          },
          "description": "Container Loglevel"
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration."
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": true,
          "config": {
            "placeholder": "n8n"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Traefik Entrypoint",
          "required": false,
          "default": "",
          "description": "Traefik entrypoint name."
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "description": "Network used for Traefik.",
          "needs": [
            "traefik_enabled=true"
          ],
          "config": {
            "placeholder": "traefik"
          }
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "Traefik Tls Entrypoint",
          "required": false,
          "default": "",
          "description": "Traefik TLS entrypoint name.",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    },
    {
      "title": "Database",
      "name": "database",
      "items": [
        {
          "name": "database_type",
          "type": "enum",
          "title": "Database Type",
          "required": false,
          "default": "sqlite",
          "description": "Database engine to use.",
          "config": {
            "options": [
              "sqlite",
              "postgres"
            ]
          }
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": true,
          "default": "postgres",
          "description": "Hostname of the database server.",
          "needs": [
            "database_type=postgres"
          ],
          "config": {
            "placeholder": "postgres"
          }
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": true,
          "default": 5432,
          "description": "Port used by the database server.",
          "needs": [
            "database_type=postgres"
          ],
          "config": {
            "placeholder": "5432"
          }
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": true,
          "default": "n8n",
          "description": "Name of the database.",
          "needs": [
            "database_type=postgres"
          ],
          "config": {
            "placeholder": "n8n"
          }
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database username",
          "required": true,
          "default": "n8n",
          "description": "Username for the database.",
          "needs": [
            "database_type=postgres"
          ],
          "config": {
            "placeholder": "n8n"
          }
        },
        {
          "name": "database_password",
          "type": "secret",
          "title": "Database password",
          "required": true,
          "description": "Password for the database.",
          "needs": [
            "database_type=postgres"
          ]
        }
      ]
    },
    {
      "title": "Security",
      "name": "security",
      "items": [
        {
          "name": "encryption_key",
          "type": "secret",
          "title": "Encryption Key",
          "required": false,
          "description": "N8N encryption key for credentials",
          "config": {
            "autogenerated": true
          }
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "External HTTP port",
          "required": false,
          "default": 5678,
          "description": "Port used for External HTTP.",
          "needs": [
            "traefik_enabled=false"
          ],
          "config": {
            "placeholder": "5678"
          }
        }
      ]
    }
  ]
}
