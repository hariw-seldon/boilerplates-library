{
  "slug": "prometheus",
  "kind": "compose",
  "metadata": {
    "name": "Prometheus",
    "description": "Open-source systems monitoring and alerting toolkit. Collects and stores metrics as time series data, with a powerful query language (PromQL) and integration with visualization tools like Grafana.",
    "tags": [
      "traefik",
      "authentik"
    ],
    "template_version": "v3.9.1",
    "icon": {
      "provider": "selfhst",
      "id": "prometheus"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "prometheus",
          "config": {
            "placeholder": "prometheus"
          },
          "description": "Name of the service."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        }
      ]
    },
    {
      "title": "Metrics & Storage",
      "name": "metrics",
      "items": [
        {
          "name": "metrics_retention_time",
          "type": "str",
          "title": "Retention Time",
          "required": false,
          "default": "15d",
          "description": "How long to retain samples (e.g., 15d, 30d, 1y)",
          "config": {
            "placeholder": "15d"
          }
        },
        {
          "name": "metrics_retention_size",
          "type": "str",
          "title": "Retention Size",
          "required": false,
          "default": "0",
          "description": "Maximum storage size (e.g., 5GB, 10GB, 1TB)",
          "config": {
            "placeholder": "0"
          }
        },
        {
          "name": "metrics_enable_remote_write",
          "type": "bool",
          "title": "Remote Write Receiver",
          "required": false,
          "default": false,
          "description": "Enable remote write receiver (allows pushing metrics via /api/v1/write)"
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "HTTP Port",
          "required": false,
          "default": 9090,
          "config": {
            "placeholder": "9090"
          },
          "description": "Host port exposed for HTTP."
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": true,
          "config": {
            "placeholder": "prometheus"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Entrypoint",
          "required": true,
          "default": "web",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "web"
          }
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "TLS Entrypoint",
          "required": true,
          "default": "websecure",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "websecure"
          },
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    }
  ]
}
