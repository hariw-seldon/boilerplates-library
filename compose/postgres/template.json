{
  "slug": "postgres",
  "kind": "compose",
  "metadata": {
    "name": "PostgreSQL",
    "description": "Powerful open-source object-relational database system with over 35 years of active development, known for reliability, feature robustness, and performance.",
    "tags": [],
    "icon": {
      "provider": "selfhst",
      "id": "postgresql"
    },
    "draft": false,
    "version": {
      "name": "18.2",
      "source_dep_name": "docker.io/library/postgres",
      "source_dep_version": "18.2"
    }
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "postgres",
          "config": {
            "placeholder": "postgres"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "postgres",
          "config": {
            "placeholder": "postgres"
          },
          "description": "Name to use for the container."
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": true,
          "description": "Hostname used inside the container."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        },
        {
          "name": "postgres_initdb_args",
          "type": "str",
          "title": "Postgres Initdb Args",
          "required": true,
          "default": "",
          "description": "Value used for the general settings."
        },
        {
          "name": "postgres_host_auth_method",
          "type": "str",
          "title": "Host Auth",
          "required": false,
          "default": "",
          "description": "Postgres Host Auth Method"
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_postgres",
          "type": "int",
          "title": "PostgreSQL port",
          "required": false,
          "default": 5432,
          "description": "Port used for Postgresql.",
          "config": {
            "placeholder": "5432"
          }
        }
      ]
    },
    {
      "title": "Network",
      "name": "network",
      "items": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false,
          "description": "Mode used for Network."
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": "postgres_network",
          "config": {
            "placeholder": "postgres_network"
          },
          "description": "Name to use for the network."
        },
        {
          "name": "network_external",
          "type": "bool",
          "title": "External Network",
          "required": false,
          "default": false,
          "description": "Whether the network is external"
        }
      ]
    },
    {
      "title": "Volume",
      "name": "volume",
      "items": [
        {
          "name": "volume_mode",
          "type": "enum",
          "title": "Volume Mode",
          "required": false,
          "default": "local",
          "description": "Volume mounting mode (local, mount, nfs)",
          "config": {
            "options": [
              "local",
              "mount",
              "nfs"
            ]
          }
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Bind Path",
          "required": false,
          "default": "/var/lib/postgresql/data",
          "description": "Path for bind mounts when volume_mode is 'mount'",
          "config": {
            "placeholder": "/var/lib/postgresql/data"
          }
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "NFS Server",
          "required": false,
          "default": "",
          "description": "NFS server address when volume_mode is 'nfs'"
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "NFS Path",
          "required": false,
          "default": "",
          "description": "NFS path when volume_mode is 'nfs'"
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "NFS Options",
          "required": false,
          "default": "rw",
          "description": "NFS mount options when volume_mode is 'nfs'",
          "config": {
            "placeholder": "rw"
          }
        }
      ]
    },
    {
      "title": "Database",
      "name": "database",
      "items": [
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": true,
          "default": "app",
          "description": "Name of the database."
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": true,
          "default": "app",
          "description": "Username for the database."
        },
        {
          "name": "database_password",
          "type": "secret",
          "title": "Database password",
          "required": true,
          "description": "Password for the database.",
          "config": {
            "autogenerated": true
          }
        }
      ]
    }
  ]
}
