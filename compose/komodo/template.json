{
  "slug": "komodo",
  "kind": "compose",
  "metadata": {
    "name": "Komodo",
    "description": "Build and deployment automation tool for managing Docker deployments, stacks, and builds across multiple servers. Features real-time container monitoring, batch operations, and a web-based management interface.",
    "tags": [
      "traefik",
      "deployment",
      "automation"
    ],
    "icon": {
      "provider": "selfhst",
      "id": "komodo"
    },
    "draft": false,
    "version": {
      "name": "1.19.5",
      "source_dep_name": "ghcr.io/moghtech/komodo-core",
      "source_dep_version": "1.19.5"
    }
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "komodo",
          "config": {
            "placeholder": "komodo"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "komodo",
          "config": {
            "placeholder": "komodo"
          },
          "description": "Name to use for the container."
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false,
          "default": "komodo",
          "config": {
            "placeholder": "komodo"
          },
          "description": "Hostname used inside the container."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        },
        {
          "name": "network_mode",
          "type": "enum",
          "title": "Network Mode",
          "required": false,
          "default": "bridge",
          "config": {
            "options": [
              "bridge",
              "macvlan",
              "host"
            ]
          },
          "description": "Mode used for Network."
        },
        {
          "name": "network_macvlan_ipv4_address",
          "type": "str",
          "title": "IPv4 Address",
          "required": false,
          "default": "",
          "description": "Network Macvlan Ipv4 Address"
        },
        {
          "name": "network_external",
          "type": "bool",
          "title": "External Network",
          "required": false,
          "default": false,
          "description": "Use external network"
        },
        {
          "name": "volume_mode",
          "type": "enum",
          "title": "Volume Mode",
          "required": false,
          "default": "local",
          "config": {
            "options": [
              "local",
              "mount",
              "nfs"
            ]
          },
          "description": "Mode used for Volume."
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "Volume Nfs Options",
          "required": false,
          "default": "",
          "description": "Mount options for the NFS volume."
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Volume Mount Path",
          "required": false,
          "default": "",
          "description": "Mount path used for the volume."
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "Volume Nfs Server",
          "required": false,
          "default": "",
          "description": "Hostname or IP address of the NFS server."
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "Volume Nfs Path",
          "required": false,
          "default": "",
          "description": "Export path on the NFS server."
        },
        {
          "name": "network_macvlan_subnet",
          "type": "str",
          "title": "Subnet",
          "required": false,
          "default": "",
          "description": "Network Macvlan Subnet"
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": "komodo_network",
          "description": "Name to use for the network."
        },
        {
          "name": "network_macvlan_parent_interface",
          "type": "str",
          "title": "Parent Interface",
          "required": false,
          "default": "",
          "description": "Network Macvlan Parent Interface"
        },
        {
          "name": "network_macvlan_gateway",
          "type": "str",
          "title": "Gateway",
          "required": false,
          "default": "",
          "description": "Network Macvlan Gateway"
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": true,
          "config": {
            "placeholder": "komodo"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Entrypoint",
          "required": true,
          "default": "web",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "web"
          }
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "TLS Entrypoint",
          "required": true,
          "default": "websecure",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "websecure"
          },
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "HTTP Port",
          "required": false,
          "default": 9120,
          "description": "External HTTP port (web interface and API)",
          "needs": [
            "traefik_enabled=false",
            "network_mode=bridge"
          ],
          "config": {
            "placeholder": "9120"
          }
        }
      ]
    },
    {
      "title": "Resource Limits",
      "toggle": "resources_enabled",
      "name": "resources",
      "items": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Resources Enabled",
          "required": false,
          "default": false,
          "description": "Enable resource limits and reservations."
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "Resources Cpu Limit",
          "required": true,
          "default": 1,
          "config": {
            "placeholder": "1"
          },
          "description": "Value used for the resource limits settings."
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Resources Memory Limit",
          "required": true,
          "default": "1G",
          "config": {
            "placeholder": "1G"
          },
          "description": "Value used for the resource limits settings."
        }
      ]
    },
    {
      "title": "Environment Variables",
      "toggle": "environment_enabled",
      "name": "environment",
      "items": [
        {
          "name": "environment_enabled",
          "type": "bool",
          "title": "Environment",
          "required": false,
          "default": true,
          "description": "Configure environment variables (required)"
        },
        {
          "name": "environment_database_address",
          "type": "str",
          "title": "Database Address",
          "required": false,
          "default": "mongodb://database:27017",
          "description": "Database connection address (MongoDB or FerretDB)",
          "needs": [
            "environment_enabled=true"
          ],
          "config": {
            "placeholder": "mongodb://database:27017"
          }
        },
        {
          "name": "environment_database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "default": "komodo",
          "description": "Name of the database.",
          "needs": [
            "environment_enabled=true"
          ],
          "config": {
            "placeholder": "komodo"
          }
        },
        {
          "name": "environment_database_username",
          "type": "str",
          "title": "DB User",
          "required": false,
          "default": "",
          "description": "Database username (optional)",
          "needs": [
            "environment_enabled=true"
          ]
        },
        {
          "name": "environment_database_password",
          "type": "secret",
          "title": "DB Password",
          "required": false,
          "default": "",
          "description": "Database password (optional)",
          "needs": [
            "environment_enabled=true"
          ]
        },
        {
          "name": "environment_jwt_secret",
          "type": "secret",
          "title": "JWT Secret",
          "required": false,
          "description": "JWT secret for authentication (auto-generated if empty)",
          "needs": [
            "environment_enabled=true"
          ],
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "environment_log_level",
          "type": "enum",
          "title": "Log level",
          "required": false,
          "default": "info",
          "description": "Logging level used for Log.",
          "needs": [
            "environment_enabled=true"
          ],
          "config": {
            "options": [
              "debug",
              "info",
              "warn",
              "error"
            ]
          }
        }
      ]
    }
  ]
}
