{
  "slug": "uptimekuma",
  "kind": "compose",
  "metadata": {
    "name": "Uptimekuma",
    "description": "Self-hosted uptime monitoring tool with support for HTTP(s), TCP, ping, DNS, and more. Provides a clean dashboard and customizable notifications.",
    "tags": [],
    "template_version": "1.23.17",
    "icon": {
      "provider": "selfhst",
      "id": "uptime-kuma"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "uptimekuma",
          "config": {
            "placeholder": "uptimekuma"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "uptimekuma",
          "config": {
            "placeholder": "uptimekuma"
          },
          "description": "Name to use for the container."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": false,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        },
        {
          "name": "volumes_version",
          "type": "str",
          "title": "Volumes version",
          "required": false,
          "default": "latest",
          "description": "Value used for the general settings.",
          "config": {
            "placeholder": "latest"
          }
        }
      ]
    }
  ]
}
