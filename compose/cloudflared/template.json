{
  "slug": "cloudflared",
  "kind": "compose",
  "metadata": {
    "name": "Cloudflared",
    "description": "Runs a Cloudflare Tunnel connector in Docker Compose so private services can be published through Cloudflare Zero Trust.",
    "tags": [],
    "template_version": "2026.3.0",
    "icon": {
      "provider": "selfhst",
      "id": "cloudflare-zero-trust"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Compose service name",
          "required": false,
          "default": "cloudflared",
          "description": "Name to use for the compose service.",
          "config": {
            "placeholder": "cloudflared"
          }
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container name",
          "required": false,
          "default": "cloudflared",
          "description": "Name to use for the container.",
          "config": {
            "placeholder": "cloudflared"
          }
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Container restart policy",
          "required": true,
          "default": "unless-stopped",
          "description": "Policy used for Container Restart.",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          }
        },
        {
          "name": "tunnel_run_command",
          "type": "str",
          "title": "Command",
          "required": false,
          "default": "tunnel --no-autoupdate run",
          "description": "Cloudflared command to run",
          "config": {
            "placeholder": "tunnel --no-autoupdate run"
          }
        },
        {
          "name": "tunnel_token",
          "type": "secret",
          "title": "Tunnel Token",
          "required": true,
          "description": "Cloudflare tunnel token used by the connector.",
          "config": {
            "autogenerated": false
          }
        }
      ]
    },
    {
      "title": "Network",
      "name": "network",
      "items": [
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": true,
          "default": "proxy",
          "description": "Docker network name for the tunnel container",
          "config": {
            "placeholder": "proxy"
          }
        },
        {
          "name": "network_external",
          "type": "bool",
          "title": "External Network",
          "required": false,
          "default": true,
          "description": "Use an existing external Docker network"
        }
      ]
    }
  ]
}
