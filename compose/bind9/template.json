{
  "slug": "bind9",
  "kind": "compose",
  "metadata": {
    "name": "BIND9",
    "description": "The most widely used authoritative and recursive DNS server. This template includes example zones, TSIG authentication for secure zone transfers, and DNSSEC support.",
    "tags": [
      "network",
      "volume"
    ],
    "template_version": "9.20-24.10_edge",
    "icon": {
      "provider": "selfhst",
      "id": "bind-9"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "dns_security",
      "name": "dns-security",
      "items": [
        {
          "name": "dnssec_enabled",
          "type": "bool",
          "title": "DNSSEC",
          "required": false,
          "description": "Enable DNSSEC"
        }
      ]
    },
    {
      "title": "dns_zone",
      "name": "dns-zone",
      "items": [
        {
          "name": "domain_name",
          "type": "str",
          "title": "Primary domain name",
          "required": false,
          "default": "home.arpa",
          "description": "Name to use for the primary domain.",
          "config": {
            "placeholder": "home.arpa"
          }
        },
        {
          "name": "tsig_enabled",
          "type": "bool",
          "title": "TSIG",
          "required": false,
          "description": "Enable TSIG"
        },
        {
          "name": "tsig_key_secret",
          "type": "secret",
          "title": "TSIG key secret",
          "required": false,
          "description": "Secret value for the tsig key.",
          "needs": [
            "tsig_enabled=true"
          ],
          "config": {
            "autogenerated": true
          }
        }
      ]
    },
    {
      "title": "Volume",
      "name": "volume",
      "items": [
        {
          "name": "volume_mode",
          "type": "enum",
          "title": "Volume Mode",
          "required": true,
          "default": "local",
          "config": {
            "options": [
              "local",
              "mount",
              "nfs"
            ]
          },
          "description": "Mode used for Volume."
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Volume Mount Path",
          "required": true,
          "default": "/data",
          "needs": [
            "volume_mode=mount"
          ],
          "config": {
            "placeholder": "/data"
          },
          "description": "Mount path used for the volume."
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "Volume Nfs Server",
          "required": true,
          "default": "NFS_SERVER",
          "needs": [
            "volume_mode=nfs"
          ],
          "config": {
            "placeholder": "NFS_SERVER"
          },
          "description": "Hostname or IP address of the NFS server."
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "Volume Nfs Path",
          "required": true,
          "default": "/export",
          "needs": [
            "volume_mode=nfs"
          ],
          "config": {
            "placeholder": "/export"
          },
          "description": "Export path on the NFS server."
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "Volume Nfs Options",
          "required": true,
          "default": "rw,nolock,soft",
          "needs": [
            "volume_mode=nfs"
          ],
          "config": {
            "placeholder": "rw,nolock,soft"
          },
          "description": "Mount options for the NFS volume."
        }
      ]
    },
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "bind9",
          "config": {
            "placeholder": "bind9"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_hostname",
          "type": "str",
          "title": "Container Hostname",
          "required": false,
          "description": "Hostname used inside the container."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        },
        {
          "name": "network_mode",
          "type": "enum",
          "title": "Network mode",
          "required": false,
          "default": "bridge",
          "description": "Mode used for Network.",
          "config": {
            "options": [
              "bridge",
              "macvlan",
              "host"
            ]
          }
        },
        {
          "name": "network_external",
          "type": "bool",
          "title": "External Network",
          "required": false,
          "default": false,
          "description": "Whether the network is external"
        },
        {
          "name": "network_macvlan_parent_interface",
          "type": "str",
          "title": "Parent Interface",
          "required": false,
          "default": "",
          "description": "Network Macvlan Parent Interface"
        },
        {
          "name": "network_macvlan_gateway",
          "type": "str",
          "title": "Gateway",
          "required": false,
          "default": "",
          "description": "Network Macvlan Gateway"
        },
        {
          "name": "network_name",
          "type": "str",
          "title": "Network Name",
          "required": false,
          "default": "bind9_network",
          "config": {
            "placeholder": "bind9_network"
          },
          "description": "Name to use for the network."
        },
        {
          "name": "network_macvlan_subnet",
          "type": "str",
          "title": "Subnet",
          "required": false,
          "default": "",
          "description": "Network Macvlan Subnet"
        },
        {
          "name": "network_macvlan_ipv4_address",
          "type": "str",
          "title": "IPv4 Address",
          "required": false,
          "default": "",
          "description": "Network Macvlan Ipv4 Address"
        }
      ]
    }
  ]
}
