{
  "slug": "checkmk",
  "kind": "compose",
  "metadata": {
    "name": "Checkmk",
    "description": "Comprehensive IT monitoring solution for infrastructure, applications, and services. Provides real-time health and performance insights with server, network, cloud, and application monitoring.",
    "tags": [
      "traefik"
    ],
    "template_version": "2.4.0-latest",
    "icon": {
      "provider": "selfhst",
      "id": "checkmk"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "checkmk",
          "config": {
            "placeholder": "checkmk"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "user_uid",
          "type": "int",
          "title": "User Uid",
          "required": false,
          "default": 1000,
          "config": {
            "placeholder": "1000"
          },
          "description": "Value used for the general settings."
        },
        {
          "name": "user_gid",
          "type": "int",
          "title": "User Gid",
          "required": false,
          "default": 1000,
          "config": {
            "placeholder": "1000"
          },
          "description": "Value used for the general settings."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        },
        {
          "name": "cmk_password",
          "type": "secret",
          "title": "CheckMK admin password",
          "required": true,
          "description": "Password for the checkmk admin.",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "cmk_site_id",
          "type": "str",
          "title": "CheckMK site ID",
          "required": true,
          "default": "cmk",
          "description": "Identifier for the checkmk site.",
          "config": {
            "placeholder": "cmk"
          }
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": false,
          "config": {
            "placeholder": "checkmk"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Entrypoint",
          "required": true,
          "default": "web",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "web"
          }
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "TLS Entrypoint",
          "required": true,
          "default": "websecure",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "websecure"
          },
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "HTTP Port",
          "required": false,
          "default": 5000,
          "config": {
            "placeholder": "5000"
          },
          "description": "Host port exposed for HTTP."
        },
        {
          "name": "ports_agent",
          "type": "int",
          "title": "Agent port",
          "required": true,
          "default": 8000,
          "description": "Port used for Agent.",
          "config": {
            "placeholder": "8000"
          }
        },
        {
          "name": "ports_snmp",
          "type": "int",
          "title": "SNMP trap port",
          "required": true,
          "default": 162,
          "description": "Port used for Snmp Trap.",
          "config": {
            "placeholder": "162"
          }
        }
      ]
    }
  ]
}
