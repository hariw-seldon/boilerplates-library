{
  "slug": "gitea",
  "kind": "compose",
  "metadata": {
    "name": "Gitea",
    "description": "Lightweight, self-hosted Git service with a web interface for repository hosting, code review, issue tracking, and team collaboration. Written in Go.",
    "tags": [
      "traefik"
    ],
    "template_version": "1.25.4",
    "icon": {
      "provider": "selfhst",
      "id": "gitea"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "gitea",
          "config": {
            "placeholder": "gitea"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "user_uid",
          "type": "int",
          "title": "User Uid",
          "required": false,
          "default": 1000,
          "config": {
            "placeholder": "1000"
          },
          "description": "Value used for the general settings."
        },
        {
          "name": "user_gid",
          "type": "int",
          "title": "User Gid",
          "required": false,
          "default": 1000,
          "config": {
            "placeholder": "1000"
          },
          "description": "Value used for the general settings."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        },
        {
          "name": "gitea_url",
          "type": "str",
          "title": "Public URL",
          "required": false,
          "default": "https://git.home.arpa",
          "description": "URL used for Public.",
          "needs": [
            "traefik_enabled=false"
          ],
          "config": {
            "placeholder": "https://git.home.arpa"
          }
        }
      ]
    },
    {
      "title": "Database",
      "name": "database",
      "items": [
        {
          "name": "database_type",
          "type": "enum",
          "title": "Database backend type",
          "required": false,
          "default": "sqlite",
          "description": "Type used for Database Backend.",
          "config": {
            "options": [
              "sqlite",
              "postgres",
              "mysql"
            ]
          }
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "default": "gitea",
          "description": "Name of the database.",
          "needs": [
            "database_type=postgres,mysql"
          ],
          "config": {
            "placeholder": "gitea"
          }
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database user",
          "required": false,
          "default": "gitea",
          "description": "Username for the database.",
          "needs": [
            "database_type=postgres,mysql"
          ],
          "config": {
            "placeholder": "gitea"
          }
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "default": "postgres",
          "description": "Hostname of the database server.",
          "needs": [
            "database_type=postgres,mysql;database_external=true"
          ],
          "config": {
            "placeholder": "postgres"
          }
        },
        {
          "name": "database_password",
          "type": "secret",
          "title": "Database password",
          "required": false,
          "description": "Password for the database.",
          "needs": [
            "database_type=postgres,mysql"
          ],
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "database_external",
          "type": "bool",
          "title": "External Database",
          "required": false,
          "default": false,
          "description": "Use external database",
          "needs": [
            "database_type=postgres,mysql"
          ]
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "HTTP Port",
          "required": false,
          "default": 3000,
          "config": {
            "placeholder": "3000"
          },
          "description": "Host port exposed for HTTP."
        },
        {
          "name": "ports_ssh",
          "type": "str",
          "title": "Ports Ssh",
          "required": false,
          "default": 2221,
          "config": {
            "placeholder": "2221"
          },
          "description": "Value used for the ports settings."
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": false,
          "config": {
            "placeholder": "gitea"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Entrypoint",
          "required": true,
          "default": "web",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "web"
          }
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "TLS Entrypoint",
          "required": true,
          "default": "websecure",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "websecure"
          },
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    }
  ]
}
