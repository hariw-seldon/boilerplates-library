{
  "slug": "homer",
  "kind": "compose",
  "metadata": {
    "name": "Homer",
    "description": "Simple static homepage for your server to keep your services on hand, configured through a single YAML file.",
    "tags": [
      "traefik",
      "authentik"
    ],
    "template_version": "v25.11.1",
    "icon": {
      "provider": "selfhst",
      "id": "homer"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "homer",
          "config": {
            "placeholder": "homer"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "homer",
          "config": {
            "placeholder": "homer"
          },
          "description": "Name to use for the container."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        },
        {
          "name": "homer_title",
          "type": "str",
          "title": "Dashboard title",
          "required": false,
          "default": "Dashboard",
          "description": "Value used for the general settings.",
          "config": {
            "placeholder": "Dashboard"
          }
        },
        {
          "name": "homer_subtitle",
          "type": "str",
          "title": "Dashboard subtitle",
          "required": false,
          "default": "Dashboard",
          "description": "Value used for the general settings.",
          "config": {
            "placeholder": "Dashboard"
          }
        },
        {
          "name": "homer_logo",
          "type": "str",
          "title": "Logo Path",
          "required": false,
          "default": "logo-file.png",
          "description": "Logo file path (relative to assets/)",
          "config": {
            "placeholder": "logo-file.png"
          }
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "HTTP Port",
          "required": false,
          "default": 8080,
          "description": "Host port for HTTP (8080)",
          "config": {
            "placeholder": "8080"
          }
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": false,
          "config": {
            "placeholder": "dashboard"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Entrypoint",
          "required": true,
          "default": "web",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "web"
          }
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "TLS Entrypoint",
          "required": true,
          "default": "websecure",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "websecure"
          },
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    },
    {
      "title": "Authentik SSO",
      "toggle": "authentik_enabled",
      "name": "authentik",
      "items": [
        {
          "name": "authentik_traefik_middleware",
          "type": "str",
          "title": "Authentik Traefik Middleware",
          "required": true,
          "default": "middleware@file",
          "needs": [
            "traefik_enabled=true"
          ],
          "config": {
            "placeholder": "middleware@file"
          },
          "description": "Middleware name."
        },
        {
          "name": "authentik_client_id",
          "type": "str",
          "title": "Client ID",
          "required": false,
          "default": "",
          "description": "Identifier for the client."
        },
        {
          "name": "authentik_client_secret",
          "type": "str",
          "title": "Client Secret",
          "required": false,
          "default": "",
          "description": "Secret value for the client."
        },
        {
          "name": "authentik_enabled",
          "type": "bool",
          "title": "Authentik SSO",
          "required": false,
          "default": false,
          "description": "Enable Authentik SSO integration"
        },
        {
          "name": "authentik_slug",
          "type": "str",
          "title": "Slug",
          "required": false,
          "default": "",
          "description": "The Authentik application slug"
        },
        {
          "name": "authentik_url",
          "type": "str",
          "title": "The Authentik URL",
          "required": false,
          "default": "",
          "description": "URL used for The Authentik."
        }
      ]
    }
  ]
}
