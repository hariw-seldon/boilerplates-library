{
  "slug": "influxdb",
  "kind": "compose",
  "metadata": {
    "name": "Influxdb",
    "description": "Open-source time series database designed for high-performance storage and retrieval of time-stamped data. Commonly used for monitoring, analytics, and IoT applications.",
    "tags": [
      "traefik"
    ],
    "icon": {
      "provider": "selfhst",
      "id": "influxdb"
    },
    "draft": false,
    "version": {
      "name": "2.8.0-alpine",
      "source_dep_name": "docker.io/library/influxdb",
      "source_dep_version": "2.8.0-alpine"
    }
  },
  "variables": [
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "HTTP API Port",
          "required": false,
          "default": 8086,
          "description": "Host port for HTTP API (8086)",
          "config": {
            "placeholder": "8086"
          }
        }
      ]
    },
    {
      "title": "Influxdb",
      "name": "influxdb",
      "items": [
        {
          "name": "influxdb_init_username",
          "type": "str",
          "title": "Initial admin username",
          "required": true,
          "default": "admin",
          "description": "Username for the initial admin.",
          "config": {
            "placeholder": "admin"
          }
        },
        {
          "name": "influxdb_init_password",
          "type": "secret",
          "title": "Initial admin password",
          "required": true,
          "description": "Password for the initial admin.",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "influxdb_init_org",
          "type": "str",
          "title": "Initial organization",
          "required": true,
          "default": "homelab",
          "description": "Organization created during the initial setup.",
          "config": {
            "placeholder": "homelab"
          }
        },
        {
          "name": "influxdb_init_bucket",
          "type": "str",
          "title": "Initial bucket",
          "required": true,
          "default": "default",
          "description": "Bucket created during the initial setup.",
          "config": {
            "placeholder": "default"
          }
        },
        {
          "name": "influxdb_init_admin_token",
          "type": "secret",
          "title": "Initial admin token",
          "required": true,
          "description": "Admin API token created during the initial setup.",
          "config": {
            "autogenerated": true
          }
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": true,
          "config": {
            "placeholder": "influxdb"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Entrypoint",
          "required": true,
          "default": "web",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "web"
          }
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "TLS Entrypoint",
          "required": true,
          "default": "websecure",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "websecure"
          },
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    },
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "influxdb",
          "config": {
            "placeholder": "influxdb"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        }
      ]
    }
  ]
}
