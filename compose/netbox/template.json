{
  "slug": "netbox-compose",
  "kind": "compose",
  "metadata": {
    "name": "NetBox",
    "description": "Network infrastructure management (IPAM/DCIM) and automation source of truth. Manages IP addresses, circuits, devices, racks, cables, and other network infrastructure components.",
    "tags": [
      "traefik",
      "database",
      "email"
    ],
    "icon": {
      "provider": "selfhst",
      "id": "netbox"
    },
    "draft": false,
    "version": {
      "name": "v4.5.10",
      "source_dep_name": "docker.io/netboxcommunity/netbox",
      "source_dep_version": "v4.5.10"
    }
  },
  "variables": [
    {
      "title": "Database",
      "name": "database",
      "items": [
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": false,
          "default": "netbox",
          "config": {
            "placeholder": "netbox"
          },
          "description": "Name of the database."
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": false,
          "default": "netbox",
          "config": {
            "placeholder": "netbox"
          },
          "description": "Username for the database."
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database Host",
          "required": true,
          "needs": [
            "database_external=true"
          ],
          "config": {
            "placeholder": "postgres"
          },
          "description": "Hostname used for Database."
        },
        {
          "name": "database_password",
          "type": "secret",
          "title": "Database Password",
          "required": true,
          "description": "Password for the database.",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "redis_password",
          "type": "secret",
          "title": "Redis Password",
          "required": true,
          "description": "Redis password for authentication",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "database_external",
          "type": "bool",
          "title": "External Database",
          "required": false,
          "default": false,
          "description": "Use external database"
        }
      ]
    },
    {
      "title": "Email",
      "toggle": "email_enabled",
      "name": "email",
      "items": [
        {
          "name": "email_host",
          "type": "str",
          "title": "SMTP server hostname",
          "required": true,
          "description": "Hostname used for SMTP Server."
        },
        {
          "name": "email_port",
          "type": "int",
          "title": "SMTP server port",
          "required": true,
          "default": 25,
          "description": "Port used for SMTP Server.",
          "config": {
            "placeholder": "25"
          }
        },
        {
          "name": "email_username",
          "type": "str",
          "title": "SMTP username",
          "required": true,
          "description": "Username for the smtp."
        },
        {
          "name": "email_password",
          "type": "secret",
          "title": "SMTP password",
          "required": true,
          "description": "Password for the smtp."
        },
        {
          "name": "email_from",
          "type": "str",
          "title": "From email address",
          "required": true,
          "description": "IP address to use for the from email."
        },
        {
          "name": "email_enabled",
          "type": "bool",
          "title": "Email",
          "required": false,
          "default": false,
          "description": "Enable email integration"
        },
        {
          "name": "email_encryption",
          "type": "str",
          "title": "Encryption",
          "required": false,
          "default": "tls",
          "description": "The email encryption type",
          "config": {
            "placeholder": "tls"
          }
        }
      ]
    },
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "netbox",
          "config": {
            "placeholder": "netbox"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        }
      ]
    },
    {
      "title": "NetBox Configuration",
      "name": "netbox",
      "items": [
        {
          "name": "netbox_metrics_enabled",
          "type": "bool",
          "title": "Metrics",
          "required": false,
          "default": false,
          "description": "Enable Prometheus metrics endpoint"
        },
        {
          "name": "netbox_secret_key",
          "type": "secret",
          "title": "Secret Key",
          "required": true,
          "description": "Value used for the netbox configuration settings.",
          "config": {
            "autogenerated": true
          }
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "HTTP Port",
          "required": false,
          "default": 8000,
          "description": "Host port for HTTP",
          "config": {
            "placeholder": "8000"
          }
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": true,
          "config": {
            "placeholder": "netbox"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Entrypoint",
          "required": true,
          "default": "web",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "web"
          }
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "TLS Entrypoint",
          "required": true,
          "default": "websecure",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "websecure"
          },
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    }
  ]
}
