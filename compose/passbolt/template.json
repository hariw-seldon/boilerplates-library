{
  "slug": "passbolt",
  "kind": "compose",
  "metadata": {
    "name": "Passbolt",
    "description": "Open-source password manager designed for teams and businesses. Provides secure storage, sharing, and collaborative management of passwords and sensitive information.",
    "tags": [
      "traefik",
      "database"
    ],
    "template_version": "5.9.0-1-ce",
    "icon": {
      "provider": "selfhst",
      "id": "passbolt"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "passbolt",
          "config": {
            "placeholder": "passbolt"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        },
        {
          "name": "ports_http",
          "type": "int",
          "title": "HTTP port",
          "required": false,
          "default": 8080,
          "description": "HTTP port for the Passbolt web UI",
          "config": {
            "placeholder": "8080"
          }
        },
        {
          "name": "app_full_base_url",
          "type": "str",
          "title": "Passbolt base URL",
          "required": false,
          "default": "http://localhost:8080",
          "description": "Public base URL for Passbolt",
          "config": {
            "placeholder": "http://localhost:8080"
          }
        }
      ]
    },
    {
      "title": "Database",
      "name": "database",
      "items": [
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": false,
          "default": "passbolt",
          "config": {
            "placeholder": "passbolt"
          },
          "description": "Name of the database."
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": false,
          "default": "passbolt",
          "config": {
            "placeholder": "passbolt"
          },
          "description": "Username for the database."
        },
        {
          "name": "database_password",
          "type": "secret",
          "title": "Database password",
          "required": true,
          "description": "Password for the database.",
          "config": {
            "autogenerated": true
          }
        }
      ]
    },
    {
      "title": "Email",
      "name": "email",
      "items": [
        {
          "name": "email_host",
          "type": "str",
          "title": "SMTP server hostname",
          "required": true,
          "config": {
            "placeholder": "smtp.home.arpa"
          },
          "description": "Hostname used for SMTP Server."
        },
        {
          "name": "email_port",
          "type": "int",
          "title": "SMTP server port",
          "required": false,
          "default": 587,
          "config": {
            "placeholder": "587"
          },
          "description": "Port used for SMTP Server."
        },
        {
          "name": "email_username",
          "type": "str",
          "title": "SMTP username",
          "required": false,
          "default": "",
          "description": "Username for the smtp."
        },
        {
          "name": "email_password",
          "type": "secret",
          "title": "SMTP password",
          "required": false,
          "default": "",
          "description": "Password for the smtp."
        },
        {
          "name": "email_from",
          "type": "str",
          "title": "From email address",
          "required": true,
          "config": {
            "placeholder": "no-reply@home.arpa"
          },
          "description": "IP address to use for the from email."
        },
        {
          "name": "email_use_tls",
          "type": "bool",
          "title": "SMTP TLS",
          "required": false,
          "default": true,
          "description": "Use TLS for SMTP"
        }
      ]
    }
  ]
}
