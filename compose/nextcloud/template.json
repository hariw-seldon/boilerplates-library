{
  "slug": "nextcloud",
  "kind": "compose",
  "metadata": {
    "name": "Nextcloud",
    "description": "Self-hosted file sync and share platform, similar to Dropbox, with built-in collaboration tools, calendar, contacts, and extensible app ecosystem.",
    "tags": [
      "traefik"
    ],
    "icon": {
      "provider": "selfhst",
      "id": "nextcloud"
    },
    "draft": false,
    "version": {
      "name": "32.0.6-apache",
      "source_dep_name": "docker.io/library/nextcloud",
      "source_dep_version": "32.0.6-apache"
    }
  },
  "variables": [
    {
      "title": "Database",
      "name": "database",
      "items": [
        {
          "name": "database_type",
          "type": "enum",
          "title": "Database Type",
          "required": false,
          "default": "postgres",
          "description": "Database type (Nextcloud supports PostgreSQL or MySQL/MariaDB)",
          "config": {
            "options": [
              "postgres",
              "mysql"
            ]
          }
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": true,
          "default": "nextcloud",
          "description": "Name of the database."
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": true,
          "default": "nextcloud",
          "description": "Username for the database."
        },
        {
          "name": "database_password",
          "type": "secret",
          "title": "Database Password",
          "required": true,
          "description": "Password for the database.",
          "config": {
            "autogenerated": true
          }
        }
      ]
    },
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "nextcloud",
          "config": {
            "placeholder": "nextcloud"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "nextcloud",
          "config": {
            "placeholder": "nextcloud"
          },
          "description": "Name to use for the container."
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "Container Timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": true,
          "config": {
            "placeholder": "nextcloud"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Traefik Entrypoint",
          "required": false,
          "default": "",
          "description": "Traefik entrypoint name."
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "Traefik Tls Entrypoint",
          "required": false,
          "default": "",
          "description": "Traefik TLS entrypoint name.",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    },
    {
      "title": "Network",
      "name": "network",
      "items": [
        {
          "name": "network_mode",
          "type": "enum",
          "title": "Network Mode",
          "required": false,
          "default": "bridge",
          "config": {
            "options": [
              "bridge",
              "macvlan"
            ]
          },
          "description": "Mode used for Network."
        },
        {
          "name": "network_macvlan_ipv4_address_db",
          "type": "str",
          "title": "Database IP",
          "required": false,
          "default": "IP_ADDRESS",
          "description": "Static IP address for database container (macvlan only)",
          "needs": [
            "network_mode=macvlan"
          ],
          "config": {
            "placeholder": "IP_ADDRESS"
          }
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "HTTP Port",
          "required": false,
          "default": 80,
          "description": "Host port for HTTP",
          "config": {
            "placeholder": "80"
          }
        }
      ]
    },
    {
      "title": "Nextcloud",
      "name": "nextcloud",
      "items": [
        {
          "name": "admin_user",
          "type": "str",
          "title": "Nextcloud admin username",
          "required": false,
          "default": "admin",
          "description": "Username for the nextcloud admin.",
          "config": {
            "placeholder": "admin"
          }
        },
        {
          "name": "admin_password",
          "type": "secret",
          "title": "Nextcloud admin password",
          "required": false,
          "description": "Password for the nextcloud admin.",
          "config": {
            "autogenerated": true
          }
        }
      ]
    }
  ]
}
