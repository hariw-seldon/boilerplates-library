{
  "slug": "semaphoreui",
  "kind": "compose",
  "metadata": {
    "name": "Semaphore UI",
    "description": "Modern web UI for Ansible automation with task scheduling, inventory management, and playbook execution. Ideal for teams who want a user-friendly way to run and monitor Ansible.",
    "tags": [
      "traefik",
      "database"
    ],
    "template_version": "v2.17.2",
    "icon": {
      "provider": "selfhst",
      "id": "semaphore-ui"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "semaphoreui",
          "config": {
            "placeholder": "semaphoreui"
          },
          "description": "Name of the service."
        },
        {
          "name": "container_name",
          "type": "str",
          "title": "Container Name",
          "required": false,
          "default": "semaphoreui",
          "config": {
            "placeholder": "semaphoreui"
          },
          "description": "Name to use for the container."
        },
        {
          "name": "restart_policy",
          "type": "enum",
          "title": "Restart Policy",
          "required": true,
          "default": "unless-stopped",
          "config": {
            "options": [
              "unless-stopped",
              "always",
              "on-failure",
              "no"
            ]
          },
          "description": "Policy used for Restart."
        },
        {
          "name": "secret_key",
          "type": "secret",
          "title": "Secret Key",
          "required": true,
          "description": "Secret key for encrypting access keys",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "admin_user",
          "type": "str",
          "title": "Administrator username",
          "required": true,
          "default": "admin",
          "description": "Username for the administrator.",
          "config": {
            "placeholder": "admin"
          }
        },
        {
          "name": "admin_name",
          "type": "str",
          "title": "Administrator full name",
          "required": true,
          "default": "Administrator",
          "description": "Name to use for the administrator full.",
          "config": {
            "placeholder": "Administrator"
          }
        },
        {
          "name": "admin_email",
          "type": "str",
          "title": "Administrator email address",
          "required": true,
          "default": "admin@home.arpa",
          "description": "IP address to use for the administrator email.",
          "config": {
            "placeholder": "admin@home.arpa"
          }
        },
        {
          "name": "admin_pass",
          "type": "secret",
          "title": "Administrator password",
          "required": true,
          "description": "Password for the administrator.",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "ansible_host_key_checking",
          "type": "bool",
          "title": "Host Key Checking",
          "required": false,
          "description": "Enable Ansible SSH host key checking"
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "str",
          "title": "HTTP Port",
          "required": false,
          "default": 3000,
          "config": {
            "placeholder": "3000"
          },
          "description": "Host port exposed for HTTP."
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": false,
          "config": {
            "placeholder": "semaphoreui"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Entrypoint",
          "required": true,
          "default": "web",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "web"
          }
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "TLS Entrypoint",
          "required": true,
          "default": "websecure",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "websecure"
          },
          "needs": [
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver",
          "needs": [
            "traefik_tls_enabled=true"
          ]
        }
      ]
    },
    {
      "title": "Database",
      "name": "database",
      "items": [
        {
          "name": "database_type",
          "type": "enum",
          "title": "Database Type",
          "required": false,
          "default": "sqlite",
          "config": {
            "options": [
              "sqlite",
              "postgres",
              "mysql"
            ]
          },
          "description": "Database engine to use."
        },
        {
          "name": "database_path",
          "type": "str",
          "title": "Database Path",
          "required": false,
          "default": "/etc/semaphore/semaphore.sqlite",
          "needs": [
            "database_type=sqlite"
          ],
          "config": {
            "placeholder": "/etc/semaphore/semaphore.sqlite"
          },
          "description": "Path to the SQLite database file."
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database Name",
          "required": false,
          "default": "semaphore",
          "needs": [
            "database_type=postgres,mysql"
          ],
          "config": {
            "placeholder": "semaphore"
          },
          "description": "Name of the database."
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database User",
          "required": false,
          "default": "semaphore",
          "needs": [
            "database_type=postgres,mysql"
          ],
          "config": {
            "placeholder": "semaphore"
          },
          "description": "Username for the database."
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database Host",
          "required": true,
          "default": "postgres",
          "needs": [
            "database_type=postgres,mysql",
            "database_external=true"
          ],
          "config": {
            "placeholder": "postgres"
          },
          "description": "Hostname used for Database."
        },
        {
          "name": "database_password",
          "type": "secret",
          "title": "Database Password",
          "required": true,
          "needs": [
            "database_type=postgres,mysql"
          ],
          "config": {
            "autogenerated": true
          },
          "description": "Password for the database."
        },
        {
          "name": "database_external",
          "type": "bool",
          "title": "External Database",
          "required": false,
          "default": false,
          "needs": [
            "database_type=postgres,mysql"
          ],
          "description": "Use external database"
        }
      ]
    }
  ]
}
