{
  "slug": "traefik-circuitbreaker",
  "kind": "kubernetes",
  "metadata": {
    "name": "Traefik CircuitBreaker Middleware",
    "description": "Traefik Middleware CRD for tripping a circuit breaker when an upstream meets a configured failure expression.",
    "tags": [],
    "template_version": "3.5.3",
    "icon": {
      "provider": "selfhst",
      "id": "traefik"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Middleware name",
          "required": false,
          "default": "protect-upstream",
          "description": "Name to use for the Middleware resource.",
          "config": {
            "placeholder": "protect-upstream"
          }
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default",
          "description": "Namespace for the Middleware resource.",
          "config": {
            "placeholder": "default"
          }
        }
      ]
    },
    {
      "title": "Circuit Breaker",
      "name": "circuitbreaker",
      "items": [
        {
          "name": "expression",
          "type": "str",
          "title": "Expression",
          "required": false,
          "default": "NetworkErrorRatio() > 0.50",
          "description": "Circuit-breaker expression evaluated by Traefik.",
          "config": {
            "placeholder": "NetworkErrorRatio() > 0.50"
          }
        }
      ]
    }
  ]
}
