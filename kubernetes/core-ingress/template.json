{
  "slug": "core-ingress",
  "kind": "kubernetes",
  "metadata": {
    "name": "Kubernetes Ingress",
    "description": "Kubernetes Ingress resource for HTTP/HTTPS routing to backend services.",
    "tags": [],
    "template_version": "1.31.0",
    "icon": {
      "provider": "simple-icons",
      "id": "kubernetes"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "app-ingress",
          "config": {
            "placeholder": "app-ingress"
          },
          "description": "Terraform resource name."
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default",
          "config": {
            "placeholder": "default"
          },
          "description": "Value used for the general settings."
        },
        {
          "name": "ingress_class",
          "type": "str",
          "title": "Ingress class name",
          "required": false,
          "default": "nginx",
          "description": "Name to use for the ingress class.",
          "config": {
            "placeholder": "nginx"
          }
        },
        {
          "name": "ingress_host",
          "type": "str",
          "title": "Ingress Host",
          "required": false,
          "description": "Hostname for the ingress"
        },
        {
          "name": "service_name",
          "type": "str",
          "title": "Backend service name",
          "required": false,
          "description": "Name to use for the backend service."
        },
        {
          "name": "service_port",
          "type": "int",
          "title": "Backend service port",
          "required": false,
          "default": 80,
          "description": "Port used for Backend Service.",
          "config": {
            "placeholder": "80"
          }
        }
      ]
    },
    {
      "title": "Resource Limits",
      "name": "resources",
      "items": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Resources",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "Value used for the resource limits settings.",
          "config": {
            "placeholder": "100m"
          }
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "Value used for the resource limits settings.",
          "config": {
            "placeholder": "50m"
          }
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Value used for the resource limits settings.",
          "config": {
            "placeholder": "128Mi"
          }
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Value used for the resource limits settings.",
          "config": {
            "placeholder": "64Mi"
          }
        }
      ]
    },
    {
      "title": "Traefik Integration",
      "name": "traefik",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": true,
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": true,
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "Certificate resolver name.",
          "config": {
            "placeholder": "letsencrypt-prod"
          }
        }
      ]
    }
  ]
}
