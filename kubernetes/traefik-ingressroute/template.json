        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": true,
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
