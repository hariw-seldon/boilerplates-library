{
  "slug": "traefik-retry",
  "kind": "kubernetes",
  "metadata": {
    "name": "Traefik Retry Middleware",
    "description": "Traefik Middleware CRD for retrying failed upstream requests with a configurable attempt count and optional initial interval.",
    "tags": [],
    "template_version": "3.5.3",
    "icon": {
      "provider": "selfhst",
      "id": "traefik"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Middleware name",
          "required": false,
          "default": "retry-upstream",
          "description": "Name to use for the Middleware resource.",
          "config": {
            "placeholder": "retry-upstream"
          }
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default",
          "description": "Namespace for the Middleware resource.",
          "config": {
            "placeholder": "default"
          }
        }
      ]
    },
    {
      "title": "Retry",
      "name": "retry",
      "items": [
        {
          "name": "attempts",
          "type": "int",
          "title": "Attempts",
          "required": false,
          "default": 3,
          "description": "Number of times Traefik should retry failed requests.",
          "config": {
            "placeholder": "3"
          }
        },
        {
          "name": "initial_interval",
          "type": "str",
          "title": "Initial interval",
          "required": false,
          "default": "100ms",
          "description": "Initial wait time before the first retry attempt.",
          "config": {
            "placeholder": "100ms"
          }
        }
      ]
    }
  ]
}
