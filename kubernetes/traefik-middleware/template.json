{
  "slug": "traefik-middleware",
  "kind": "kubernetes",
  "metadata": {
    "name": "Traefik Middleware",
    "description": "Traefik Middleware CRD for modifying HTTP requests and responses. Supports headers, redirects, rate-limiting, authentication, and more.",
    "tags": [],
    "icon": {
      "provider": "selfhst",
      "id": "traefik"
    },
    "draft": false,
    "version": {
      "name": "3.5.3",
      "source_dep_name": "manual/traefik-middleware"
    }
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "resource_name",
          "type": "str",
          "title": "Resource Name",
          "required": false,
          "default": "app-middleware",
          "config": {
            "placeholder": "app-middleware"
          },
          "description": "Terraform resource name."
        },
        {
          "name": "namespace",
          "type": "str",
          "title": "Namespace",
          "required": false,
          "default": "default",
          "config": {
            "placeholder": "default"
          },
          "description": "Value used for the general settings."
        },
        {
          "name": "middleware_type",
          "type": "enum",
          "title": "Middleware type",
          "required": false,
          "default": "redirectScheme",
          "description": "Type used for Middleware.",
          "config": {
            "options": [
              "redirectScheme",
              "stripPrefix",
              "addPrefix",
              "headers",
              "rateLimit"
            ]
          }
        }
      ]
    },
    {
      "title": "Resource Limits",
      "name": "resources",
      "items": [
        {
          "name": "resources_enabled",
          "type": "bool",
          "title": "Resources",
          "required": false,
          "default": false,
          "description": "Enable resource limits and requests"
        },
        {
          "name": "resources_cpu_limit",
          "type": "str",
          "title": "CPU limit",
          "required": false,
          "default": "100m",
          "description": "Value used for the resource limits settings.",
          "config": {
            "placeholder": "100m"
          }
        },
        {
          "name": "resources_cpu_request",
          "type": "str",
          "title": "CPU request",
          "required": false,
          "default": "50m",
          "description": "Value used for the resource limits settings.",
          "config": {
            "placeholder": "50m"
          }
        },
        {
          "name": "resources_memory_limit",
          "type": "str",
          "title": "Memory limit",
          "required": false,
          "default": "128Mi",
          "description": "Value used for the resource limits settings.",
          "config": {
            "placeholder": "128Mi"
          }
        },
        {
          "name": "resources_memory_request",
          "type": "str",
          "title": "Memory request",
          "required": false,
          "default": "64Mi",
          "description": "Value used for the resource limits settings.",
          "config": {
            "placeholder": "64Mi"
          }
        }
      ]
    },
    {
      "title": "Traefik Integration",
      "name": "traefik",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik host",
          "required": true,
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Traefik domain",
          "required": true,
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": true,
          "description": "Enable TLS"
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "TLS certificate resolver",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "Certificate resolver name.",
          "config": {
            "placeholder": "letsencrypt-prod"
          }
        }
      ]
    }
  ]
}
