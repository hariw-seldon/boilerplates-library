{
  "slug": "docker-cleanup",
  "kind": "ansible",
  "metadata": {
    "name": "Docker Cleanup",
    "description": "Safely prunes Docker resources on target hosts. Only removes resources that are explicitly enabled in the configuration, keeping a conservative default.",
    "tags": [
      "docker",
      "cleanup",
      "prune",
      "maintenance"
    ],
    "icon": {
      "provider": "mdi",
      "id": "broom",
      "color": "fuchsia"
    },
    "draft": false,
    "version": {
      "name": "1",
      "source_dep_name": "manual/docker-cleanup"
    }
  },
  "variables": [
    {
      "title": "Prune Options",
      "name": "prune",
      "items": [
        {
          "name": "prune_include_unused_tagged_images",
          "type": "bool",
          "title": "Tagged Images",
          "required": false,
          "default": false,
          "description": "Enable pruning of unused tagged images in addition to dangling images"
        },
        {
          "name": "prune_stopped_containers",
          "type": "bool",
          "title": "Prune Stopped Containers",
          "required": false,
          "default": false,
          "description": "Remove stopped containers"
        },
        {
          "name": "prune_unused_volumes",
          "type": "bool",
          "title": "Prune Unused Volumes",
          "required": false,
          "default": false,
          "description": "Remove unused volumes"
        },
        {
          "name": "prune_unused_networks",
          "type": "bool",
          "title": "Prune Unused Networks",
          "required": false,
          "default": false,
          "description": "Remove unused networks"
        },
        {
          "name": "prune_builder_cache",
          "type": "bool",
          "title": "Prune Builder Cache",
          "required": false,
          "default": false,
          "description": "Remove unused build cache"
        },
        {
          "name": "prune_keep_storage_mb",
          "type": "int",
          "title": "Keep Storage",
          "required": false,
          "default": 1024,
          "description": "Minimum amount of cache/storage to keep when pruning (where supported)",
          "config": {
            "slider": true,
            "min": 256,
            "max": 102400,
            "step": 256,
            "placeholder": "1024",
            "unit": "MB"
          }
        }
      ]
    }
  ]
}
