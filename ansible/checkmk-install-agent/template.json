{
  "slug": "checkmk-install-agent",
  "kind": "ansible",
  "metadata": {
    "name": "Install Checkmk Agent",
    "description": "Installs and registers the Checkmk monitoring agent on target hosts using the checkmk.general.agent Ansible role.",
    "tags": [],
    "template_version": "2.4.0",
    "icon": {
      "provider": "selfhst",
      "id": "checkmk"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "Checkmk Configuration",
      "name": "checkmk",
      "items": [
        {
          "name": "checkmk_server",
          "type": "str",
          "title": "Checkmk Server",
          "required": true,
          "description": "Value used for the checkmk configuration settings."
        },
        {
          "name": "checkmk_protocol",
          "type": "str",
          "title": "Protocol",
          "required": true,
          "default": "https",
          "description": "Checkmk Server Protocol",
          "config": {
            "placeholder": "https"
          }
        },
        {
          "name": "checkmk_site",
          "type": "str",
          "title": "Checkmk Site",
          "required": true,
          "default": "cmk",
          "description": "Value used for the checkmk configuration settings.",
          "config": {
            "placeholder": "cmk"
          }
        },
        {
          "name": "checkmk_auto_activate",
          "type": "bool",
          "title": "Auto Activate Agent",
          "required": false,
          "description": "Enable or disable auto activate agent."
        },
        {
          "name": "checkmk_tls",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "description": "Use TLS for Agent Communication"
        },
        {
          "name": "checkmk_user",
          "type": "str",
          "title": "Checkmk Automation User",
          "required": true,
          "description": "Username for the checkmk automation."
        },
        {
          "name": "checkmk_pass",
          "type": "secret",
          "title": "Automation Password",
          "required": true,
          "description": "Checkmk Automation User Password"
        },
        {
          "name": "checkmk_host",
          "type": "str",
          "title": "Checkmk Host Name",
          "required": true,
          "description": "Name to use for the checkmk host."
        }
      ]
    }
  ]
}
