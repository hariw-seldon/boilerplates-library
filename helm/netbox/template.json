{
  "slug": "netbox-helm",
  "kind": "helm",
  "metadata": {
    "name": "NetBox",
    "description": "Helm chart for NetBox, an open-source network infrastructure management (IPAM/DCIM) solution and network automation source of truth.",
    "tags": [],
    "template_version": "4.2.3",
    "icon": {
      "provider": "selfhst",
      "id": "netbox"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "Database Configuration",
      "name": "database",
      "items": [
        {
          "name": "database_external",
          "type": "bool",
          "title": "External Database",
          "required": false,
          "default": false,
          "description": "Use an external PostgreSQL database"
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "default": "netbox-postgresql",
          "description": "Hostname of the database server.",
          "needs": [
            "database_external=true"
          ],
          "config": {
            "placeholder": "netbox-postgresql"
          }
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": false,
          "default": 5432,
          "description": "Port used by the database server.",
          "needs": [
            "database_external=true"
          ],
          "config": {
            "placeholder": "5432"
          }
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "default": "netbox",
          "description": "Name of the database.",
          "config": {
            "placeholder": "netbox"
          }
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database user",
          "required": false,
          "default": "netbox",
          "description": "Username for the database.",
          "config": {
            "placeholder": "netbox"
          }
        },
        {
          "name": "database_password",
          "type": "secret",
          "title": "Database password",
          "required": false,
          "description": "Password for the database.",
          "config": {
            "autogenerated": true
          }
        }
      ]
    },
    {
      "title": "Networking Configuration",
      "name": "networking",
      "items": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false,
          "default": "ClusterIP",
          "description": "Network mode for service",
          "config": {
            "placeholder": "ClusterIP"
          }
        }
      ]
    },
    {
      "title": "Redis Configuration",
      "name": "redis",
      "items": [
        {
          "name": "redis_external",
          "type": "bool",
          "title": "External Redis",
          "required": false,
          "default": false,
          "description": "Use an external Redis deployment"
        },
        {
          "name": "redis_host",
          "type": "str",
          "title": "Redis Host",
          "required": false,
          "default": "netbox-redis-master",
          "description": "Redis host for tasks",
          "needs": [
            "redis_external=true"
          ],
          "config": {
            "placeholder": "netbox-redis-master"
          }
        },
        {
          "name": "redis_cache_host",
          "type": "str",
          "title": "Cache Host",
          "required": false,
          "default": "netbox-redis-master",
          "description": "Redis host for caching",
          "needs": [
            "redis_external=true"
          ],
          "config": {
            "placeholder": "netbox-redis-master"
          }
        },
        {
          "name": "redis_password",
          "type": "secret",
          "title": "Redis password",
          "required": false,
          "description": "Password for the redis.",
          "config": {
            "autogenerated": true
          }
        }
      ]
    },
    {
      "title": "Email Configuration",
      "name": "email",
      "items": [
        {
          "name": "email_enabled",
          "type": "bool",
          "title": "Email",
          "required": false,
          "default": false,
          "description": "Enable email notifications"
        },
        {
          "name": "email_host",
          "type": "str",
          "title": "SMTP server hostname",
          "required": false,
          "description": "Hostname used for SMTP Server.",
          "config": {
            "placeholder": "smtp.home.arpa"
          }
        },
        {
          "name": "email_port",
          "type": "int",
          "title": "SMTP server port",
          "required": false,
          "default": 587,
          "description": "Port used for SMTP Server.",
          "config": {
            "placeholder": "587"
          }
        },
        {
          "name": "email_username",
          "type": "str",
          "title": "SMTP username",
          "required": false,
          "default": "",
          "description": "Username for the smtp."
        },
        {
          "name": "email_password",
          "type": "secret",
          "title": "SMTP password",
          "required": false,
          "description": "Password for the smtp.",
          "needs": [
            "email_enabled=true"
          ]
        },
        {
          "name": "email_from",
          "type": "str",
          "title": "From email address",
          "required": false,
          "description": "IP address to use for the from email.",
          "config": {
            "placeholder": "netbox@home.arpa"
          }
        },
        {
          "name": "email_use_tls",
          "type": "bool",
          "title": "SMTP TLS",
          "required": false,
          "default": true,
          "description": "Use TLS/STARTTLS for SMTP connection"
        },
        {
          "name": "email_use_ssl",
          "type": "bool",
          "title": "SMTP SSL",
          "required": false,
          "default": false,
          "description": "Use SSL for SMTP connection"
        }
      ]
    },
    {
      "title": "Traefik Configuration",
      "name": "traefik",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik ingress"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik hostname",
          "required": false,
          "description": "Hostname used for Traefik.",
          "config": {
            "placeholder": "netbox.home.arpa"
          }
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable TLS for Traefik ingress"
        },
        {
          "name": "traefik_tls_secret",
          "type": "str",
          "title": "TLS Secret",
          "required": false,
          "default": "netbox-tls",
          "description": "TLS secret name for Traefik ingress",
          "config": {
            "placeholder": "netbox-tls"
          }
        },
        {
          "name": "traefik_tls_certmanager",
          "type": "bool",
          "title": "Cert Manager",
          "required": false,
          "default": false,
          "description": "Use cert-manager for TLS certificate"
        },
        {
          "name": "certmanager_issuer",
          "type": "str",
          "title": "Issuer",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "Cert-manager issuer name",
          "needs": [
            "traefik_tls_certmanager=true"
          ],
          "config": {
            "placeholder": "letsencrypt-prod"
          }
        }
      ]
    },
    {
      "title": "Volume Configuration",
      "name": "volumes",
      "items": [
        {
          "name": "volumes_mode",
          "type": "enum",
          "title": "Persistence mode",
          "required": false,
          "default": "chart-managed",
          "description": "Mode used for Persistence.",
          "config": {
            "options": [
              "chart-managed",
              "existing-pvc"
            ]
          }
        },
        {
          "name": "volumes_pvc_name",
          "type": "str",
          "title": "PVC Name",
          "required": false,
          "default": "netbox-data",
          "description": "Name to use for the pvc.",
          "needs": [
            "volumes_mode=existing-pvc"
          ],
          "config": {
            "placeholder": "netbox-data"
          }
        }
      ]
    },
    {
      "title": "NetBox Configuration",
      "name": "netbox",
      "items": [
        {
          "name": "netbox_secret_key",
          "type": "secret",
          "title": "Secret Key",
          "required": false,
          "description": "Value used for the netbox configuration settings.",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "netbox_superuser_name",
          "type": "str",
          "title": "Initial superuser username",
          "required": false,
          "default": "admin",
          "description": "Username for the initial superuser.",
          "config": {
            "placeholder": "admin"
          }
        },
        {
          "name": "netbox_superuser_email",
          "type": "str",
          "title": "Initial superuser email",
          "required": false,
          "description": "Value used for the netbox configuration settings.",
          "config": {
            "placeholder": "admin@home.arpa"
          }
        },
        {
          "name": "netbox_superuser_password",
          "type": "secret",
          "title": "Initial superuser password",
          "required": false,
          "description": "Password for the initial superuser.",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "netbox_superuser_api_token",
          "type": "secret",
          "title": "API Token",
          "required": false,
          "description": "Initial superuser API token",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "netbox_allowed_hosts",
          "type": "str",
          "title": "Allowed Hosts",
          "required": false,
          "default": "*",
          "description": "Allowed hosts (comma-separated)",
          "config": {
            "placeholder": "*"
          }
        },
        {
          "name": "netbox_metrics_enabled",
          "type": "bool",
          "title": "Metrics",
          "required": false,
          "default": false,
          "description": "Enable Prometheus metrics endpoint"
        },
        {
          "name": "netbox_cors_enabled",
          "type": "bool",
          "title": "CORS",
          "required": false,
          "default": false,
          "description": "Enable CORS (Cross-Origin Resource Sharing)"
        },
        {
          "name": "netbox_cors_origins",
          "type": "str",
          "title": "Allowed CORS origins",
          "required": false,
          "default": "https://home.arpa",
          "description": "Value used for the netbox configuration settings.",
          "needs": [
            "netbox_cors_enabled=true"
          ],
          "config": {
            "placeholder": "https://home.arpa"
          }
        }
      ]
    }
  ]
}
