{
  "slug": "portainer-helm",
  "kind": "helm",
  "metadata": {
    "name": "Portainer CE",
    "description": "Helm chart for Portainer Community Edition, a web-based container management platform for Docker and Kubernetes environments.",
    "tags": [],
    "template_version": "2.34.0",
    "icon": {
      "provider": "selfhst",
      "id": "portainer"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "Networking",
      "name": "networking",
      "items": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false,
          "default": "ClusterIP",
          "description": "Network mode for service",
          "config": {
            "placeholder": "ClusterIP"
          }
        }
      ]
    },
    {
      "title": "Traefik Configuration",
      "name": "traefik",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik ingress"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik hostname",
          "required": false,
          "description": "Hostname used for Traefik.",
          "config": {
            "placeholder": "portainer.home.arpa"
          }
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable TLS for Traefik ingress"
        },
        {
          "name": "traefik_tls_secret",
          "type": "str",
          "title": "TLS Secret",
          "required": false,
          "default": "portainer-tls",
          "description": "TLS secret name for Traefik ingress",
          "config": {
            "placeholder": "portainer-tls"
          }
        }
      ]
    },
    {
      "title": "Volume Configuration",
      "name": "volumes",
      "items": [
        {
          "name": "volumes_mode",
          "type": "enum",
          "title": "Persistence mode",
          "required": false,
          "default": "chart-managed",
          "description": "Mode used for Persistence.",
          "config": {
            "options": [
              "chart-managed",
              "existing-pvc"
            ]
          }
        },
        {
          "name": "volumes_pvc_name",
          "type": "str",
          "title": "PVC Name",
          "required": false,
          "default": "portainer",
          "description": "Name to use for the pvc.",
          "needs": [
            "volumes_mode=existing-pvc"
          ],
          "config": {
            "placeholder": "portainer"
          }
        }
      ]
    }
  ]
}
