{
  "slug": "authentik-helm",
  "kind": "helm",
  "metadata": {
    "name": "Authentik",
    "description": "Helm chart for Authentik, an open-source Identity Provider supporting OAuth2, SAML, and LDAP for flexible single sign-on and authentication.",
    "tags": [],
    "template_version": "2025.6.3",
    "icon": {
      "provider": "selfhst",
      "id": "authentik"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "Networking",
      "name": "networking",
      "items": [
        {
          "name": "network_mode",
          "type": "str",
          "title": "Network Mode",
          "required": false,
          "default": "ClusterIP",
          "description": "Network mode for service",
          "config": {
            "placeholder": "ClusterIP"
          }
        }
      ]
    },
    {
      "title": "Authentik Configuration",
      "name": "authentik",
      "items": [
        {
          "name": "authentik_secret_key",
          "type": "secret",
          "title": "Secret Key",
          "required": false,
          "description": "Value used for the authentik configuration settings.",
          "config": {
            "autogenerated": true
          }
        },
        {
          "name": "authentik_log_level",
          "type": "enum",
          "title": "Authentik log level",
          "required": false,
          "default": "error",
          "description": "Logging level used for Authentik Log.",
          "config": {
            "options": [
              "trace",
              "debug",
              "info",
              "warning",
              "error"
            ]
          }
        },
        {
          "name": "authentik_error_reporting",
          "type": "bool",
          "title": "Error Reporting",
          "required": false,
          "default": false,
          "description": "Enable error reporting to Authentik developers"
        }
      ]
    },
    {
      "title": "Database Configuration",
      "name": "database",
      "items": [
        {
          "name": "database_external",
          "type": "bool",
          "title": "External Database",
          "required": false,
          "default": false,
          "description": "Use an external PostgreSQL database"
        },
        {
          "name": "database_host",
          "type": "str",
          "title": "Database host",
          "required": false,
          "default": "authentik-postgresql",
          "description": "Hostname of the database server.",
          "needs": [
            "database_external=true"
          ],
          "config": {
            "placeholder": "authentik-postgresql"
          }
        },
        {
          "name": "database_port",
          "type": "int",
          "title": "Database port",
          "required": false,
          "default": 5432,
          "description": "Port used by the database server.",
          "needs": [
            "database_external=true"
          ],
          "config": {
            "placeholder": "5432"
          }
        },
        {
          "name": "database_name",
          "type": "str",
          "title": "Database name",
          "required": false,
          "default": "authentik",
          "description": "Name of the database.",
          "config": {
            "placeholder": "authentik"
          }
        },
        {
          "name": "database_user",
          "type": "str",
          "title": "Database user",
          "required": false,
          "default": "authentik",
          "description": "Username for the database.",
          "config": {
            "placeholder": "authentik"
          }
        },
        {
          "name": "database_password",
          "type": "secret",
          "title": "PostgreSQL database password",
          "required": false,
          "description": "Password for the postgresql database.",
          "config": {
            "autogenerated": true
          }
        }
      ]
    },
    {
      "title": "Email Configuration",
      "name": "email",
      "items": [
        {
          "name": "email_enabled",
          "type": "bool",
          "title": "Email",
          "required": false,
          "default": false,
          "description": "Enable email notifications"
        },
        {
          "name": "email_host",
          "type": "str",
          "title": "SMTP server hostname",
          "required": false,
          "description": "Hostname used for SMTP Server.",
          "config": {
            "placeholder": "smtp.home.arpa"
          }
        },
        {
          "name": "email_port",
          "type": "int",
          "title": "SMTP server port",
          "required": false,
          "default": 587,
          "description": "Port used for SMTP Server.",
          "config": {
            "placeholder": "587"
          }
        },
        {
          "name": "email_username",
          "type": "str",
          "title": "SMTP username",
          "required": false,
          "default": "",
          "description": "Username for the smtp."
        },
        {
          "name": "email_password",
          "type": "secret",
          "title": "SMTP password",
          "required": false,
          "default": "",
          "description": "Password for the smtp."
        },
        {
          "name": "email_from",
          "type": "str",
          "title": "From email address",
          "required": false,
          "description": "IP address to use for the from email.",
          "config": {
            "placeholder": "authentik@home.arpa"
          }
        },
        {
          "name": "email_use_tls",
          "type": "bool",
          "title": "SMTP TLS",
          "required": false,
          "default": true,
          "description": "Use TLS/STARTTLS for SMTP connection"
        }
      ]
    },
    {
      "title": "Traefik Configuration",
      "name": "traefik",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik ingress"
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Traefik hostname",
          "required": false,
          "description": "Hostname used for Traefik.",
          "config": {
            "placeholder": "authentik.home.arpa"
          }
        },
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable TLS for Traefik ingress"
        },
        {
          "name": "traefik_tls_secret",
          "type": "str",
          "title": "TLS Secret",
          "required": false,
          "default": "authentik-tls",
          "description": "TLS secret name for Traefik ingress",
          "config": {
            "placeholder": "authentik-tls"
          }
        },
        {
          "name": "traefik_tls_certmanager",
          "type": "bool",
          "title": "Cert Manager",
          "required": false,
          "default": false,
          "description": "Use cert-manager for TLS certificate"
        },
        {
          "name": "certmanager_issuer",
          "type": "str",
          "title": "Issuer",
          "required": false,
          "default": "letsencrypt-prod",
          "description": "Cert-manager issuer name",
          "needs": [
            "traefik_tls_certmanager=true"
          ],
          "config": {
            "placeholder": "letsencrypt-prod"
          }
        }
      ]
    }
  ]
}
