{
  "slug": "homepage-swarm",
  "kind": "swarm",
  "metadata": {
    "name": "Homepage",
    "description": "Modern, fully static, fast application dashboard with integrations for over 100 services and translations into multiple languages.",
    "tags": [
      "traefik",
      "volume_modes"
    ],
    "template_version": "v1.10.1",
    "icon": {
      "provider": "selfhst",
      "id": "homepage"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "The service name",
          "required": true,
          "default": "homepage",
          "description": "Name of the service.",
          "config": {
            "placeholder": "homepage"
          }
        },
        {
          "name": "container_timezone",
          "type": "str",
          "title": "The container timezone",
          "required": false,
          "description": "Timezone used inside the container."
        },
        {
          "name": "container_loglevel",
          "type": "enum",
          "title": "Log Level",
          "required": false,
          "description": "The container log level",
          "config": {
            "options": [
              "debug",
              "info",
              "warn",
              "error"
            ]
          }
        },
        {
          "name": "swarm_placement_mode",
          "type": "enum",
          "title": "Swarm Placement Mode",
          "required": true,
          "default": "replicated",
          "config": {
            "options": [
              "replicated",
              "global"
            ]
          },
          "description": "Mode used for Swarm Placement."
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Swarm Replicas",
          "required": false,
          "default": 1,
          "config": {
            "slider": true,
            "min": 1,
            "max": 10,
            "step": 1,
            "placeholder": "1",
            "unit": "replicas"
          },
          "description": "Number of replicas to run.",
          "needs": [
            "swarm_placement_mode=replicated"
          ]
        },
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "Swarm Placement Host",
          "required": false,
          "default": "",
          "description": "Hostname used for Swarm Placement.",
          "needs": [
            "swarm_placement_mode=replicated"
          ],
          "config": {
            "placeholder": "swarm-node-1"
          }
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "The HTTP port",
          "required": true,
          "default": 3000,
          "description": "Host port exposed for HTTP.",
          "needs": [
            "traefik_enabled=false"
          ],
          "config": {
            "placeholder": "3000"
          }
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik",
          "required": false,
          "default": false,
          "description": "Enable Traefik integration"
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Entrypoint",
          "required": true,
          "default": "web",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "web"
          }
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": true,
          "config": {
            "placeholder": "homepage"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": true,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": true,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        }
      ]
    },
    {
      "title": "Traefik TLS",
      "name": "traefik-tls",
      "toggle": "traefik_tls_enabled",
      "items": [
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "TLS Entrypoint",
          "required": true,
          "default": "websecure",
          "description": "Entrypoint name.",
          "config": {
            "placeholder": "websecure"
          }
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": true,
          "default": "cloudflare",
          "config": {
            "placeholder": "cloudflare"
          },
          "description": "Traefik Tls Certresolver"
        }
      ]
    },
    {
      "title": "Volume",
      "name": "volume",
      "items": [
        {
          "name": "volume_mode",
          "type": "enum",
          "title": "Volume Mode",
          "required": true,
          "default": "local",
          "config": {
            "options": [
              "local",
              "mount",
              "nfs"
            ]
          },
          "description": "Mode used for Volume."
        },
        {
          "name": "volume_mount_path",
          "type": "str",
          "title": "Volume Mount Path",
          "required": true,
          "default": "/mnt/storage",
          "needs": [
            "volume_mode=mount"
          ],
          "config": {
            "placeholder": "/mnt/storage"
          },
          "description": "Mount path used for the volume."
        },
        {
          "name": "volume_nfs_options",
          "type": "str",
          "title": "NFS Options",
          "required": false,
          "default": "nfsvers=4,soft,timeo=180,intr",
          "description": "The NFS mount options",
          "config": {
            "placeholder": "nfsvers=4,soft,timeo=180,intr"
          },
          "needs": [
            "volume_mode=nfs"
          ]
        },
        {
          "name": "volume_nfs_path",
          "type": "str",
          "title": "NFS Path",
          "required": false,
          "default": "",
          "description": "Export path on the NFS server.",
          "needs": [
            "volume_mode=nfs"
          ],
          "config": {
            "placeholder": "/path/to/export"
          }
        },
        {
          "name": "volume_nfs_server",
          "type": "str",
          "title": "NFS Server",
          "required": false,
          "default": "",
          "description": "Hostname or IP address of the NFS server.",
          "needs": [
            "volume_mode=nfs"
          ],
          "config": {
            "placeholder": "192.0.2.1"
          }
        }
      ]
    }
  ]
}
