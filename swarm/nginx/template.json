{
  "slug": "nginx-swarm",
  "kind": "swarm",
  "metadata": {
    "name": "Nginx",
    "description": "High-performance web server, reverse proxy, and load balancer known for stability, low resource consumption, and simple configuration.",
    "guide": "## Overview\nHigh-performance web server, reverse proxy, and load balancer known for stability, low resource consumption, and simple configuration.\n\n## Prerequisites\n- Decide on replica count, placement constraints, published ports, and whether the service will be exposed directly or through Traefik.\n- Prepare your site content, reverse-proxy config, and any TLS material separately before deploying to production.\n- If you enable Traefik, make sure the target network and DNS record already exist.\n\n## Deploy\n- Render the generated files, review the routing and placement settings, and deploy with `docker stack deploy -c compose.yaml <stack-name>`.\n- Verify that the tasks land on the expected nodes and that the service responds on the configured ports or ingress route.\n\n## Post-Install\n- Validate direct port access and any Traefik routing before sending real traffic to the stack.\n- Replace placeholder content or server blocks with your intended site configuration.\n- Monitor replica placement after node restarts so Swarm keeps the service where you expect it.\n\n## References\n- [Nginx](https://nginx.org/)\n- [Documentation](https://nginx.org/en/docs/)\n- [GitHub](https://github.com/nginx/nginx)",
    "tags": [
      "traefik"
    ],
    "template_version": "1.28.2-alpine",
    "icon": {
      "provider": "simple-icons",
      "id": "nginx"
    },
    "draft": false
  },
  "variables": [
    {
      "title": "General",
      "name": "general",
      "items": [
        {
          "name": "service_name",
          "type": "str",
          "title": "Service Name",
          "required": false,
          "default": "nginx",
          "config": {
            "placeholder": "nginx"
          },
          "description": "Name of the service."
        },
        {
          "name": "traefik_tls_entrypoint",
          "type": "str",
          "title": "Traefik Tls Entrypoint",
          "required": false,
          "default": "",
          "description": "Traefik TLS entrypoint name.",
          "config": {
            "placeholder": "websecure"
          },
          "needs": [
            "traefik_enabled=true",
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "traefik_tls_certresolver",
          "type": "str",
          "title": "Cert Resolver",
          "required": false,
          "default": "",
          "description": "Traefik Tls Certresolver",
          "config": {
            "placeholder": "cloudflare"
          },
          "needs": [
            "traefik_enabled=true",
            "traefik_tls_enabled=true"
          ]
        },
        {
          "name": "swarm_replicas",
          "type": "int",
          "title": "Replicas",
          "required": false,
          "default": 1,
          "description": "Number of replicas for Swarm mode",
          "config": {
            "slider": true,
            "min": 1,
            "max": 20,
            "step": 1,
            "placeholder": "1",
            "unit": "replicas"
          }
        },
        {
          "name": "swarm_placement_host",
          "type": "str",
          "title": "The placement host",
          "required": false,
          "default": "",
          "description": "Hostname used for placement constraints.",
          "config": {
            "placeholder": "swarm-node-1"
          }
        },
        {
          "name": "swarm_placement_mode",
          "type": "enum",
          "title": "The placement mode",
          "required": false,
          "default": "replicated",
          "description": "Placement mode for the service.",
          "config": {
            "options": [
              "replicated",
              "global"
            ]
          }
        }
      ]
    },
    {
      "title": "Ports",
      "name": "ports",
      "items": [
        {
          "name": "ports_http",
          "type": "int",
          "title": "HTTP Port",
          "required": false,
          "default": 8080,
          "description": "HTTP port for nginx service",
          "config": {
            "placeholder": "8080"
          },
          "needs": [
            "traefik_enabled=false"
          ]
        },
        {
          "name": "ports_https",
          "type": "int",
          "title": "HTTPS Port",
          "required": false,
          "default": 8443,
          "description": "HTTPS port for nginx service",
          "config": {
            "placeholder": "8443"
          },
          "needs": [
            "traefik_enabled=false"
          ]
        }
      ]
    },
    {
      "title": "Traefik",
      "name": "traefik",
      "toggle": "traefik_enabled",
      "items": [
        {
          "name": "traefik_enabled",
          "type": "bool",
          "title": "Traefik Enabled",
          "required": false,
          "default": false,
          "description": "Enable or disable traefik enabled."
        },
        {
          "name": "traefik_network",
          "type": "str",
          "title": "Network",
          "required": false,
          "default": "traefik",
          "config": {
            "placeholder": "traefik"
          },
          "description": "Network used for Traefik."
        },
        {
          "name": "traefik_host",
          "type": "str",
          "title": "Host",
          "required": false,
          "config": {
            "placeholder": "nginx"
          },
          "description": "Hostname used for Traefik."
        },
        {
          "name": "traefik_domain",
          "type": "str",
          "title": "Domain",
          "required": false,
          "config": {
            "placeholder": "home.arpa"
          },
          "description": "Domain used for Traefik."
        },
        {
          "name": "traefik_entrypoint",
          "type": "str",
          "title": "Traefik Entrypoint",
          "required": false,
          "default": "web",
          "description": "Traefik entrypoint name.",
          "config": {
            "placeholder": "web"
          },
          "needs": [
            "traefik_enabled=true"
          ]
        }
      ]
    },
    {
      "title": "Traefik TLS",
      "toggle": "traefik_tls_enabled",
      "name": "traefik-tls",
      "items": [
        {
          "name": "traefik_tls_enabled",
          "type": "bool",
          "title": "TLS",
          "required": false,
          "default": false,
          "description": "Enable Traefik TLS"
        }
      ]
    }
  ]
}
